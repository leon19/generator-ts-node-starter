{
  "name": "generator-ts-node-starter",
  "version": "0.0.0-development",
  "description": "Generator for ts-node-starter repository",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Lorens León",
    "email": "lorensleon@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leon19/generator-ts-node-starter"
  },
  "keywords": [
    "yeoman-generator"
  ],
  "files": [
    "generators"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "yeoman-generator": "^8.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.4.0",
    "@swc-node/register": "^1.11.1",
    "@types/node": "*",
    "@types/yeoman-assert": "^3.1.4",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "yeoman-assert": "^3.1.1",
    "yeoman-environment": "^6.0.1",
    "yeoman-test": "^11.3.1"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf reports .tmp",
    "test": "node --env-file .env.test --test 'tests/generator.test.ts'",
    "cover": "c8 node --run test",
    "lint": "biome check --write --unsafe src && prettier --write '*.md'",
    "prepublishOnly": "node --run build",
    "prepare": "husky || exit 0"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
